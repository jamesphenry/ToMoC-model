[Unit]
Description=GPU fan PID controller for Dell PowerEdge (watchdog)
After=multi-user.target
Wants=multi-user.target

[Service]
Type=simple
ExecStart=/usr/local/bin/gpu-fan-wrapper.sh
ExecStopPost=/usr/bin/ipmitool raw 0x30 0x30 0x01 0x01
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
